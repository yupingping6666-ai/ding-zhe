# Server Configuration
PORT=3001
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dingzhe
DB_USER=postgres
DB_PASSWORD=

# JWT
JWT_SECRET=ding-zhe-secret-key-change-in-production
JWT_EXPIRES_IN=30d

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Kimi K2.5 (Moonshot AI) - AI小橘聊天、叙事生成、图片分析
# 获取 API Key: https://platform.kimi.com/
KIMI_API_KEY=your-kimi-api-key-here
KIMI_MODEL=kimi-k2.5
KIMI_VL_MODEL=kimi-k2.5
KIMI_BASE_URL=https://coding.dashscope.aliyuncs.com/v1

# QWeather 和风天气 (免费版: https://dev.qweather.com)
QWEATHER_API_KEY=your-qweather-api-key-here
